# Express Server Configuration
PORT=3001

# Google Sheets Configuration
# Retrieve these values by creating a Service Account in the Google Cloud Console.
GOOGLE_PROJECT_ID=your_project_id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your_service_account_email@your_project_id.iam.gserviceaccount.com

# The ID of your Google Sheet. You can find this in the URL of your Google Sheet.
# Example: https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
GOOGLE_SHEET_ID=your_spreadsheet_id

# Email Configuration (Nodemailer)
# Use your SMTP provider details or a Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin_email_to_receive_notifications@example.com
